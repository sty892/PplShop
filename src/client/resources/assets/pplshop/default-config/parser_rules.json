{
  "require_currency_for_price": true,
  "reject_bare_numbers_as_price": true,
  "reject_dates_as_price": true,
  "prefer_right_side_as_price": true,
  "count_words": [
    "шт",
    "шт.",
    "штука",
    "штуки",
    "штук",
    "ст",
    "ст.",
    "стак",
    "стака",
    "стаков",
    "слот",
    "слота",
    "слотов",
    "шб",
    "шб.",
    "лот",
    "лота",
    "книга",
    "книги",
    "кирка",
    "ведро",
    "ведра",
    "вёдра",
    "блок",
    "блока",
    "блоков",
    "сл",
    "сл.",
    "слиток",
    "слитка",
    "слитков",
    "сет",
    "сета",
    "сетов",
    "сосуд",
    "сосуда",
    "сосудов"
  ],
  "ignore_if_contains": [
    "спасибо",
    "заранее спасибо",
    "зарание спасибо",
    "цена внутри",
    "скоро пополню",
    "написано",
    "умер от пинга",
    "если увидите",
    "кто вещи оставл",
    "и не подписал",
    "бесплатные арты",
    "реклама",
    "объявления",
    "на обороте",
    "попа",
    "пизда",
    "мефедрончик",
    "мефедрон",
    "меф",
    "деньги на ветер",
    "с любовью"
  ],
  "ignore_if_line_matches": [
    "^[0-9]{1,2}[./,][0-9]{1,2}([./,][0-9]{2,4})?$",
    "^[=\\-_.❤☀★✦⚠⏹⏴⏵◄►☺🔥`ω´✘▍▌ ]+$",
    "^[A-Za-z0-9_@]{3,20}$"
  ],
  "normalize": {
    "lowercase": true,
    "replace_yo_with_e": true,
    "collapse_spaces": true,
    "strip_decorative_symbols": true,
    "strip_punctuation_noise": true
  },
  "merge_item_lines": [
    [
      "line1",
      "line2"
    ],
    [
      "line2",
      "line3"
    ],
    [
      "line1"
    ],
    [
      "line2"
    ],
    [
      "line3"
    ]
  ],
  "price_patterns": [
    "(?<count>[0-9]+)\\s*(?<countWord>шт|шт\\.|штука|штуки|штук|ст|ст\\.|стак|стака|стаков|слот|слота|слотов|шб|шб\\.|лот|лота|блок|блока|блоков|сл|сл\\.|слиток|слитка|слитков|сет|сета|сетов|сосуд|сосуда|сосудов)\\s*[-=➜/]+\\s*(?<amount>[0-9]+)\\s*(?<currency>аб|aб|ab|алм блок|алмазный блок|алмазные блоки|алм|алмаз|алмаза|алмазов|алмазы|ал|aлм|aл|alm|diam|diamond|diamonds)\\b",
    "(?<amount>[0-9]+)\\s*(?<currency>аб|aб|ab|алм блок|алмазный блок|алмазные блоки|алм|алмаз|алмаза|алмазов|алмазы|ал|aлм|aл|alm|diam|diamond|diamonds)\\s*(за|/)\\s*(?<countWord>шт|штуку|стак|слот|шб|книгу|ведро|блок|слиток|сет|сосуд)\\b",
    "(?<countWord>слот|стак|шб|шт|штука|книга|ведро|блок|сл|слиток|сет|сосуд)\\s*[-=➜/ ]+\\s*(?<amount>[0-9]+)\\s*(?<currency>аб|aб|ab|алм блок|алмазный блок|алмазные блоки|алм|алмаз|алмаза|алмазов|алмазы|ал|aлм|aл|alm|diam|diamond|diamonds)\\b",
    "\\((?<amount>[0-9]+)\\s*(?<currency>аб|aб|ab|алм|алмаз|алмаза|алмазов)\\)",
    "(?<free>бесплатно|беспл|free|даром)\\b"
  ],
  "line_priority": [
    3,
    2,
    1,
    4
  ],
  "price_line_hints": [
    "line3",
    "line2",
    "line1"
  ],
  "ignore_player_name_line4_if_matches_nickname": true,
  "sort_unknown_entries_to_bottom": true
}