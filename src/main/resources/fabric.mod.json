{
  "schemaVersion": 1,
  "id": "pplshop",
  "version": "${version}",
  "name": "PPLShop",
  "description": "Client-side shop browser for sign-based stores.",
  "authors": [
    "styy_"
  ],
  "icon": "icon.png",
  "contact": {},
  "license": "GPL-3.0-only",
  "environment": "client",
  "entrypoints": {
    "fabric-datagen": [
      "styy.pplShop.pplshop.client.PplshopDataGenerator"
    ],
    "client": [
      "styy.pplShop.pplshop.client.PplshopClient"
    ],
    "modmenu": [
      "styy.pplShop.pplshop.client.integration.PplShopModMenuIntegration"
    ],
    "main": [
      "styy.pplShop.pplshop.Pplshop"
    ]
  },
  "mixins": [
    "pplshop.mixins.json",
    {
      "config": "pplshop.client.mixins.json",
      "environment": "client"
    }
  ],
  "depends": {
    "fabricloader": ">=${loader_version}",
    "fabric-api": "*",
    "minecraft": "${minecraft_version}",
    "modmenu": ">=15.0.0"
  }
}
